# --- Real backend (same as admin portal) ---
# When set to your API (not DummyJSON), sign-in uses POST /auth/login there.
# VITE_API_BASE_URL=http://localhost:4000

# --- Optional overrides ---
# Force DummyJSON demo login in dev:
# VITE_USE_AUTH_MOCK=true
#
# Force real /auth/login even in dev (e.g. you use a local API):
# VITE_USE_AUTH_MOCK=false
# VITE_API_BASE_URL=http://localhost:4000
